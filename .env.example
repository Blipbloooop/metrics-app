# ============================================================
# metrics-app — Variables d'environnement
# ============================================================
# Copier ce fichier en .env.local pour le développement local,
# ou configurer ces valeurs dans le Secret K8s (metrics-app-secrets)
# pour le déploiement en production.
# ============================================================

# --- Base de données (REQUIS) ---
DATABASE_URL="postgresql://metrics_user:metrics-password@postgres.default.svc.cluster.local:5432/k8s_metrics"

# --- Prediction Service ---
# URL du prediction-service (Express, maintenu par Romain)
PREDICTION_SERVICE_URL="http://prediction-service.ai-module.svc.cluster.local:3001"

# --- Configuration Ollama (PRV-26) ---
# Ces options sont envoyées au prediction-service dans le payload
# quand SEND_OLLAMA_CONFIG=true. Le prediction-service doit lire
# le champ "ollama_options" du payload et le passer à Ollama.
# Désactivé par défaut tant que le prediction-service ne le supporte pas.
SEND_OLLAMA_CONFIG=false
OLLAMA_MODEL="qwen2:0.5b"
OLLAMA_TEMPERATURE=0.1          # 0.0-1.0, contrôle la créativité
OLLAMA_NUM_PREDICT=256           # tokens max générés (128-512)
OLLAMA_STREAM=false

# --- Seuils de risque de surcharge (PRV-24) ---
# Seuils CPU (%) pour l'évaluation du risque
RISK_CPU_MEDIUM=80
RISK_CPU_HIGH=90
# Seuils RAM (%) pour l'évaluation du risque
RISK_RAM_MEDIUM=85
RISK_RAM_HIGH=95

# --- Prometheus ---
PROMETHEUS_URL="http://monitoring-kube-prometheus-prometheus.monitoring.svc:9090"
PROMETHEUS_ENABLED=false

# --- Collecteur Kubernetes ---
KUBE_COLLECTOR_ENABLED=false
KUBE_COLLECTOR_INTERVAL=30000   # intervalle en ms
KUBE_NAMESPACE="default"
# KUBE_CONFIG_PATH=             # chemin vers kubeconfig (dev local uniquement)

# --- Ingestion de métriques (REQUIS si scraper actif) ---
INGEST_URL="http://localhost:3000"
METRICS_INGEST_TOKEN="votre-token-ici"


# ============================================================
# GUIDE DE DEPLOIEMENT — pour Romain
# ============================================================
#
# 1. PULL + BUILD + DEPLOIEMENT
# ----------------------------------------------------------
#   cd /home/romain/metrics-app
#   git pull
#   docker build --no-cache -t metrics-app:latest .
#   docker save metrics-app:latest -o /tmp/metrics-app.tar
#   scp /tmp/metrics-app.tar romain@192.168.10.126:/tmp/
#   scp /tmp/metrics-app.tar romain@192.168.10.243:/tmp/
#
#   Sur chaque worker (en root) :
#     docker load -i /tmp/metrics-app.tar
#
#   Puis depuis le master :
#     kubectl rollout restart deployment/metrics-app -n app-production
#     kubectl rollout status deployment/metrics-app -n app-production
#
#
# 2. TESTER LES ENDPOINTS
# ----------------------------------------------------------
#   # Forecast (prédiction itérative multi-pas)
#   curl -s -X POST http://10.109.48.39:3000/api/forecast \
#     -H "Content-Type: application/json" \
#     -d '{"node_id":"k8s-worker-1","horizon_minutes":30,"step_minutes":5}' | jq .
#
#   # Predict (prédiction ponctuelle)
#   curl -s -X POST http://10.109.48.39:3000/api/predict \
#     -H "Content-Type: application/json" \
#     -d '{"node_id":"k8s-worker-1","current_cpu_percent":45,"current_ram_percent":60,"current_disk_percent":30,"trend_direction":"up","prediction_horizon_minutes":30}' | jq .
#
#
# 3. MODIFIER LES VARIABLES EN PRODUCTION (K8s)
# ----------------------------------------------------------
#   Ajouter une env var au deployment :
#     kubectl set env deployment/metrics-app -n app-production RISK_CPU_HIGH=95
#
#   Ou éditer le manifest k8s/nextjs-app.yaml et réappliquer :
#     kubectl apply -f k8s/nextjs-app.yaml
#
#
# 4. LOGS ET DEBUG
# ----------------------------------------------------------
#   kubectl logs deployment/metrics-app -n app-production --tail=30
#   kubectl describe pod -l app=metrics-app -n app-production
#   kubectl exec deployment/metrics-app -n app-production -- cat /app/.next/server/app/api/forecast/route.js | grep -o 'inference_time_ms[^,}]*'
#
#
# 5. CONTRAT API — prediction-service (PRV-27)
# ----------------------------------------------------------
#   Le metrics-app valide les réponses du prediction-service avec Zod.
#   Si le format ne correspond pas, l'erreur sera explicite dans les logs.
#
#   /forecast — Payload envoyé :
#     { "node": "k8s-worker-1", "cpu_history": [...], "ram_history": [...],
#       "horizon_minutes": 30, "step_minutes": 5 }
#   /forecast — Réponse attendue :
#     { "node": "str", "forecast": [{"t":"+5min","cpu_percent":N,"ram_percent":N},...],
#       "cpu_avg": N, "cpu_peak": N, "ram_avg": N, "ram_peak": N,
#       "model_used": "str", "timestamp": "ISO" }
#
#   /predict — Payload envoyé :
#     { "node_id": "k8s-worker-1", "current_cpu_percent": N,
#       "current_ram_percent": N, "current_disk_percent": N,
#       "trend_direction": "up|down|stable", "prediction_horizon_minutes": N }
#   /predict — Réponse attendue :
#     { "request_id": "str", "timestamp": "ISO",
#       "prediction": { "predicted_cpu_percent": 0-100, "predicted_ram_percent": 0-100,
#         "predicted_disk_percent": 0-100, "overload_risk": 0-1,
#         "confidence": 0-1, "recommendation": "str" },
#       "model_info": { "model_name": "str", "inference_time_ms": N,
#         "tokens_generated": N } }
#
#   NOTE: /predict renvoie actuellement 400. Le prediction-service doit
#   être adapté pour accepter ce format de payload.
#
#
# 6. ACTIVER LA CONFIG OLLAMA (PRV-26)
# ----------------------------------------------------------
#   Quand le prediction-service supportera les champs prompt_template
#   et ollama_options dans le payload, activer avec :
#     kubectl set env deployment/metrics-app -n app-production SEND_OLLAMA_CONFIG=true
#
#   Le payload envoyé inclura alors :
#     "prompt_template": "...",
#     "ollama_options": { "model": "qwen2:0.5b", "temperature": 0.1,
#                         "num_predict": 256, "stream": false }
#
#   Le prediction-service doit lire ollama_options et le passer à
#   l'API Ollama /api/generate (options.temperature, options.num_predict, etc.)
